{
  "name": "saas-project-management-api",
  "version": "1.0.0",
  "description": "Multi-tenant SaaS Project Management System – Backend API",
  "type": "module",
  "main": "dist/src/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "prestart": "npm run build",
    "start": "node dist/src/server.js",
    "dev": "nodemon --watch src --watch seed-admin.ts --ext ts --exec \"npm run build && node dist/src/server.js\"",
    "lint": "eslint src/",
    "test": "npm run build && cross-env NODE_OPTIONS=--experimental-vm-modules jest --runInBand dist/tests",
    "test:watch": "npm run build && cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch dist/tests",
    "test:coverage": "npm run build && cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage --runInBand dist/tests"
  },
  "dependencies": {
    "@types/nodemailer": "^6.4.15",
    "@types/uuid": "^10.0.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.4.0",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.5",
    "pdfkit": "^0.18.0",
    "resend": "^6.11.0",
    "socket.io": "^4.8.3",
    "stripe": "^22.0.0",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-mongodb": "^7.0.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.0",
    "@types/pdfkit": "^0.17.5",
    "@types/supertest": "^7.2.0",
    "cross-env": "^10.1.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.3",
    "supertest": "^7.2.2",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
