# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/saas_pm_dev

# ─── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://project-management-system-bice-nine.vercel.app

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_ENABLED=false      # Set true to enforce in non-production
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes in ms
RATE_LIMIT_MAX=100            # Max requests per window

# ─── Auth (JWT) ───────────────────────────────────────────────
JWT_ACCESS_SECRET=your_access_token_secret_here
JWT_REFRESH_SECRET=your_refresh_token_secret_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Email (Resend) ───────────────────────────────────────────
# Production email provider for Render/Vercel deployments.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=PMS Orbit <noreply@trusttracker.live>
# Resend requires trusttracker.live to be verified in the Resend dashboard before sending to other recipients.
# Replace with another verified sender only after the domain is added and confirmed.
# If true, invite API returns 500 when email delivery fails.
# If false, invite is still created and API returns success with emailDelivery metadata.
INVITE_EMAIL_REQUIRED=false

# ─── Frontend URL (used in email links) ───────────────────────
FRONTEND_URL=https://project-management-system-bice-nine.vercel.app
