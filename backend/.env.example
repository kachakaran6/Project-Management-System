# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/saas_pm_dev

# ─── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://project-management-system-bice-nine.vercel.app

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_ENABLED=false      # Set true to enforce in non-production
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes in ms
RATE_LIMIT_MAX=100            # Max requests per window

# ─── Auth (JWT) ───────────────────────────────────────────────
JWT_ACCESS_SECRET=your_access_token_secret_here
JWT_REFRESH_SECRET=your_refresh_token_secret_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── SMTP (Email / OTP) ───────────────────────────────────────
# Use any SMTP provider: Gmail, SendGrid, Mailgun, Resend, etc.
# For development/testing you can use Ethereal: https://ethereal.email
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_FAMILY=4
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
# Render compatibility aliases (optional): if set, these are used when SMTP_USER/SMTP_PASS are missing
EMAIL_USER=your_smtp_username
EMAIL_PASS=your_smtp_app_password
SMTP_FROM="PMS Orbit <noreply@pms-orbit.io>"
SMTP_DEBUG=false
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=10000
# Email provider: smtp or sendgrid
EMAIL_PROVIDER=smtp
SENDGRID_API_KEY=
# If true, invite API returns 500 when email delivery fails.
# If false, invite is still created and API returns success with emailDelivery metadata.
INVITE_EMAIL_REQUIRED=false

# ─── Frontend URL (used in email links) ───────────────────────
FRONTEND_URL=https://project-management-system-bice-nine.vercel.app
